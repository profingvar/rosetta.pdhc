FLASK_ENV=development
FLASK_APP=app:create_app
APP_PORT=9092

DB_HOST=localhost
DB_PORT=9091
DB_NAME=rosetta_pdhc_db
DB_USER=rosetta
DB_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://rosetta:changeme@localhost:9091/rosetta_pdhc_db

AUTH_MODE=off
SSO_BASE_URL=https://sso.pdhc.se
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL=https://rosetta.pdhc.se/auth/callback
GATEWAY_BASE_URL=https://gateway.pdhc.se

SECRET_KEY=replace-me-with-random-string
# #422 — ips.pdhc consent verdicts (analysis-filter). Required in prod;
# unset => analysis reads fail closed (503) for non-SU users.
IPS_BASE_URL=https://ips.pdhc.se
